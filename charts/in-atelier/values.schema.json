{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "global",
    "publicSurface",
    "environmentProfile",
    "deployment",
    "platform",
    "config",
    "apisix",
    "keycloak",
    "postgresql",
    "mongodb",
    "kafka",
    "openwhisk",
    "storage",
    "observability",
    "controlPlane",
    "webConsole"
  ],
  "properties": {
    "global": {
      "type": "object",
      "required": [
        "nameOverride",
        "namespace",
        "environment",
        "createNamespace",
        "airgap",
        "privateRegistry"
      ],
      "properties": {
        "nameOverride": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "sandbox",
            "staging",
            "prod"
          ]
        },
        "createNamespace": {
          "type": "boolean"
        },
        "imageRegistry": {
          "type": "string"
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "object"
            ]
          }
        },
        "airgap": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "privateRegistry": {
          "type": "object",
          "required": [
            "enabled",
            "registry",
            "pullSecretNames",
            "caBundleConfigMap"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "registry": {
              "type": "string"
            },
            "pullSecretNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "caBundleConfigMap": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "defaultStorageClass": {
          "type": "string"
        },
        "podSecurity": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "publicSurface": {
      "type": "object",
      "required": [
        "routePrefixes",
        "hostnames",
        "certificates",
        "bindings"
      ],
      "properties": {
        "routePrefixes": {
          "type": "object",
          "required": [
            "controlPlane",
            "identity",
            "realtime",
            "console"
          ],
          "properties": {
            "controlPlane": {
              "type": "string"
            },
            "identity": {
              "type": "string"
            },
            "realtime": {
              "type": "string"
            },
            "console": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "optionalWorkspaceSubdomains": {
          "type": "object"
        },
        "hostnames": {
          "type": "object",
          "required": [
            "api",
            "console",
            "identity",
            "realtime"
          ],
          "properties": {
            "api": {
              "type": "string",
              "minLength": 1
            },
            "console": {
              "type": "string",
              "minLength": 1
            },
            "identity": {
              "type": "string",
              "minLength": 1
            },
            "realtime": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "certificates": {
          "type": "object",
          "required": [
            "wildcardSecretName",
            "surfaces"
          ],
          "properties": {
            "wildcardSecretName": {
              "type": "string",
              "minLength": 1
            },
            "surfaces": {
              "type": "object",
              "required": [
                "api",
                "console",
                "identity",
                "realtime"
              ],
              "properties": {
                "api": {
                  "type": "string",
                  "minLength": 1
                },
                "console": {
                  "type": "string",
                  "minLength": 1
                },
                "identity": {
                  "type": "string",
                  "minLength": 1
                },
                "realtime": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "bindings": {
          "type": "object",
          "required": [
            "api",
            "identity",
            "realtime",
            "console"
          ],
          "properties": {
            "api": {
              "type": "object",
              "required": [
                "component",
                "serviceName",
                "servicePort",
                "path"
              ],
              "properties": {
                "component": {
                  "type": "string",
                  "minLength": 1
                },
                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "identity": {
              "type": "object",
              "required": [
                "component",
                "serviceName",
                "servicePort",
                "path"
              ],
              "properties": {
                "component": {
                  "type": "string",
                  "minLength": 1
                },
                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "realtime": {
              "type": "object",
              "required": [
                "component",
                "serviceName",
                "servicePort",
                "path"
              ],
              "properties": {
                "component": {
                  "type": "string",
                  "minLength": 1
                },
                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "console": {
              "type": "object",
              "required": [
                "component",
                "serviceName",
                "servicePort",
                "path"
              ],
              "properties": {
                "component": {
                  "type": "string",
                  "minLength": 1
                },
                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "ingress": {
          "type": "object"
        },
        "route": {
          "type": "object",
          "properties": {
            "annotations": {
              "type": "object"
            },
            "tls": {
              "type": "object",
              "properties": {
                "termination": {
                  "type": "string"
                },
                "insecureEdgeTerminationPolicy": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "tls": {
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "clusterManaged",
                "external"
              ]
            }
          },
          "additionalProperties": true
        },
        "loadBalancer": {
          "type": "object",
          "properties": {
            "annotations": {
              "type": "object"
            },
            "className": {
              "type": "string"
            },
            "ports": {
              "type": "object",
              "required": [
                "api",
                "console",
                "identity",
                "realtime"
              ],
              "properties": {
                "api": {
                  "type": "number"
                },
                "console": {
                  "type": "number"
                },
                "identity": {
                  "type": "number"
                },
                "realtime": {
                  "type": "number"
                }
              },
              "additionalProperties": true
            },
            "sourceRanges": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "externalTrafficPolicy": {
              "type": "string",
              "enum": [
                "Cluster",
                "Local"
              ]
            },
            "ipFamilyPolicy": {
              "type": "string"
            },
            "ipFamilies": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allocateLoadBalancerNodePorts": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "environmentProfile": {
      "type": "object"
    },
    "deployment": {
      "type": "object",
      "required": [
        "topology",
        "valuesLayers",
        "profile",
        "recommendedProfiles",
        "upgrade"
      ],
      "properties": {
        "topology": {
          "type": "object"
        },
        "valuesLayers": {
          "type": "object",
          "required": [
            "common",
            "environment",
            "customer",
            "platform",
            "airgap",
            "localOverride"
          ],
          "properties": {
            "common": {
              "type": "string"
            },
            "environment": {
              "type": "string"
            },
            "customer": {
              "type": "string"
            },
            "platform": {
              "type": "string"
            },
            "airgap": {
              "type": "string"
            },
            "localOverride": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "profile": {
          "type": "string",
          "enum": [
            "all-in-one",
            "standard",
            "ha"
          ]
        },
        "recommendedProfiles": {
          "type": "object",
          "required": [
            "default",
            "pathPattern",
            "supported"
          ],
          "properties": {
            "default": {
              "type": "string",
              "enum": [
                "standard"
              ]
            },
            "pathPattern": {
              "type": "string"
            },
            "supported": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "all-in-one",
                  "standard",
                  "ha"
                ]
              }
            }
          },
          "additionalProperties": true
        },
        "upgrade": {
          "type": "object",
          "required": [
            "allowInPlace",
            "currentVersion",
            "supportedPreviousVersions",
            "allowDowngrade",
            "strategy"
          ],
          "properties": {
            "allowInPlace": {
              "type": "boolean"
            },
            "currentVersion": {
              "type": "string"
            },
            "supportedPreviousVersions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowDowngrade": {
              "type": "boolean"
            },
            "strategy": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "platform": {
      "type": "object"
    },
    "config": {
      "type": "object"
    },
    "apisix": {
      "$ref": "#/definitions/component"
    },
    "keycloak": {
      "$ref": "#/definitions/component"
    },
    "postgresql": {
      "$ref": "#/definitions/component"
    },
    "mongodb": {
      "$ref": "#/definitions/component"
    },
    "kafka": {
      "$ref": "#/definitions/component"
    },
    "openwhisk": {
      "$ref": "#/definitions/component"
    },
    "storage": {
      "$ref": "#/definitions/component"
    },
    "observability": {
      "$ref": "#/definitions/component"
    },
    "controlPlane": {
      "$ref": "#/definitions/component"
    },
    "webConsole": {
      "$ref": "#/definitions/component"
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "required": [
        "repository"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "pullPolicy": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "tag"
          ]
        },
        {
          "required": [
            "digest"
          ]
        }
      ],
      "additionalProperties": true
    },
    "service": {
      "type": "object",
      "required": [
        "enabled",
        "type",
        "port",
        "targetPort",
        "portName"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "targetPort": {
          "type": [
            "integer",
            "string"
          ]
        },
        "portName": {
          "type": "string",
          "minLength": 1
        },
        "annotations": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object"
        },
        "limits": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "persistence": {
      "type": "object",
      "required": [
        "enabled",
        "existingClaim",
        "size",
        "storageClass",
        "accessModes",
        "mountPath"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "existingClaim": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "storageClass": {
          "type": "string"
        },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "annotations": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "component": {
      "type": "object",
      "required": [
        "enabled",
        "wrapper",
        "image",
        "replicas",
        "service",
        "resources",
        "persistence"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "wrapper": {
          "type": "object",
          "required": [
            "componentId",
            "workload"
          ],
          "properties": {
            "componentId": {
              "type": "string",
              "minLength": 1
            },
            "workload": {
              "type": "object",
              "required": [
                "kind"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "Deployment",
                    "StatefulSet"
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "image": {
          "$ref": "#/definitions/image"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "replicas": {
          "type": "integer",
          "minimum": 0
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            },
            "automountToken": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "service": {
          "$ref": "#/definitions/service"
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "resources": {
          "$ref": "#/definitions/resources"
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "envFromSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "envFromConfigMaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "persistence": {
          "$ref": "#/definitions/persistence"
        },
        "podAnnotations": {
          "type": "object"
        },
        "podLabels": {
          "type": "object"
        },
        "podSecurityContext": {
          "type": "object"
        },
        "securityContext": {
          "type": "object"
        },
        "nodeSelector": {
          "type": "object"
        },
        "tolerations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "affinity": {
          "type": "object"
        },
        "extraVolumes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "extraVolumeMounts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "inline": {
              "type": "object",
              "additionalProperties": {
                "type": [
                  "string",
                  "number",
                  "boolean"
                ]
              }
            }
          },
          "additionalProperties": true
        },
        "initContainers": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "volumePermissions": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "image": {
              "type": "object",
              "properties": {
                "repository": {
                  "type": "string",
                  "minLength": 1
                },
                "tag": {
                  "type": "string",
                  "minLength": 1
                },
                "pullPolicy": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            },
            "command": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "securityContext": {
              "type": "object"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
